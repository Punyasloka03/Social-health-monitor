{
  "manifest_version": 3,
  "name": "Social Media Health Monitor",
  "version": "1.0",
  "description": "Detects doom scrolling using behavioral and sentiment signals",
  
  "permissions": ["storage", "activeTab", "scripting"],

  "host_permissions": [
    "*://*.instagram.com/*",
    "*://*.twitter.com/*",
    "*://*.youtube.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["sentiment.js", "dsri.js", "content.js"]
    }
  ]
}
